{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=orchi.db"
  },
  "Agents": {
    "Cursor": {
      "Executable": "agent",
      "DefaultArgs": ["--force", "--trust"],
      "TimeoutSeconds": 600
    }
  },
  "SharedContext": {
    "ConnectionString": "Data Source=orchi-context.db",
    "MaxFilesPerIndex": 10000,
    "IndexStaleAfter": "01:00:00",
    "RetrievalTopK": 8,
    "RetrievalTokenBudget": 4000
  },
  "Performance": {
    "SlowQueryThresholdMs": 500,
    "SlowCommandThresholdMs": 1000
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
