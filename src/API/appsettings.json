{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=orchi.db"
  },
  "Agents": {
    "Cursor": {
      "Executable": "agent",
      "DefaultArgs": ["--force", "--trust"],
      "TimeoutSeconds": 600
    }
  },
  "Performance": {
    "SlowQueryThresholdMs": 500,
    "SlowCommandThresholdMs": 1000
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
