{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=orchi.db"
  },
  "Agents": {
    "Cursor": {
      "Executable": "agent",
      "DefaultArgs": ["--force", "--trust"],
      "TimeoutSeconds": 600
    }
  },
  "Cache": {
    "DefaultExpirationMinutes": 5,
    "WorkspaceDiffExpirationSeconds": 30,
    "CursorExecutableExpirationMinutes": 60,
    "PlanExpirationMinutes": 10,
    "Distributed": {
      "Enabled": false,
      "Provider": "None",
      "ConnectionString": ""
    }
  },
  "Performance": {
    "SlowQueryThresholdMs": 500,
    "SlowCommandThresholdMs": 1000
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
