{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch API (browser)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-api",
      "program": "${workspaceFolder}/src/API/bin/Debug/net10.0/Orchi.Api.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/API",
      "stopAtEntry": false,
      "justMyCode": false,
      "suppressJITOptimizations": true,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5265",
        "COMPlus_ReadyToRun": "0",
        "COMPlus_ZapDisable": "1"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
        "uriFormat": "%s/scalar/v1"
      }
    },
    {
      "name": "Launch API (no browser)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-api",
      "program": "${workspaceFolder}/src/API/bin/Debug/net10.0/Orchi.Api.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/API",
      "stopAtEntry": false,
      "justMyCode": false,
      "suppressJITOptimizations": true,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5265",
        "COMPlus_ReadyToRun": "0",
        "COMPlus_ZapDisable": "1"
      }
    },
    {
      "name": "Attach to API",
      "type": "coreclr",
      "request": "attach",
      "processName": "Orchi.Api",
      "justMyCode": false,
      "suppressJITOptimizations": true
    }
  ]
}
