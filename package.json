{
  "name": "orchi",
  "private": true,
  "scripts": {
    "dev": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev.ps1",
    "dev:api": "dotnet run --project src/API",
    "dev:desktop": "npm run dev --prefix src/desktop",
    "dev:isolated": "npm run dev",
    "setup:runtime": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup-runtime.ps1",
    "start:runtime": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-runtime.ps1",
    "test:api": "dotnet test tests/Orchi.Api.Tests",
    "audit": "npm audit --audit-level=high && npm audit --prefix src/desktop --audit-level=high",
    "lint": "npm run audit && npm run lint --prefix src/desktop",
    "prepare": "husky"
  },
  "devDependencies": {
    "concurrently": "^9.2.4",
    "husky": "^9.1.7",
    "wait-on": "^9.1.0"
  }
}
